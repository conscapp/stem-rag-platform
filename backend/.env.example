# Qdrant Cloud
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
COLLECTION_NAME=stem_vectors

# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Embedding model (1024-dim: bge-large-en-v1.5 or BAAI/bge-m3 — recreate collection on change)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_QUERY_PREFIX=true

# RAG settings
TOP_K=5
CHUNK_SIZE=1200
CHUNK_OVERLAP=120
MAX_OUTPUT_TOKENS=2000

# Hybrid retrieval (dense + BM25 reciprocal rank fusion)
HYBRID_SEARCH_ENABLED=true
HYBRID_FETCH_MULTIPLIER=4
HYBRID_RRF_K=60
BM25_INDEX_PATH=data/index/bm25_corpus.json

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production example:
# CORS_ORIGINS=https://conscrag.com,https://www.conscrag.com,https://your-app.vercel.app
# Optional regex for Vercel preview deployments:
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
CORS_ORIGIN_REGEX=

# Admin review (set a strong secret; used in X-Admin-Key header)
ADMIN_API_KEY=change-me-to-a-strong-secret

# Innovation gate thresholds
NOVELTY_DUPLICATE_THRESHOLD=0.88
NOVELTY_AUTO_REJECT_SCORE=35
NOVELTY_MIN_DISCIPLINES=2
INNOVATION_COLLECTION_NAME=innovation_vectors
