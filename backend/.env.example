# Qdrant Cloud
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
COLLECTION_NAME=stem_vectors

# DeepSeek API (agents)
DEEPSEEK_API_KEY=your-deepseek-api-key

# Embeddings — production default: OpenAI (small API server, no GPU/RAM model)
# openai | voyage | local
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1024
EMBEDDING_QUERY_PREFIX=false
WARM_EMBEDDING_ON_STARTUP=false

# Alternative: Voyage (often strong for retrieval)
# EMBEDDING_PROVIDER=voyage
# VOYAGE_API_KEY=your-voyage-api-key
# EMBEDDING_MODEL=voyage-3-large
# EMBEDDING_DIMENSIONS=1024

# Local fallback (needs: pip install -r requirements-local.txt)
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# EMBEDDING_QUERY_PREFIX=true

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# RAG settings
TOP_K=5
CHUNK_SIZE=1200
CHUNK_OVERLAP=120
MAX_OUTPUT_TOKENS=2000

# Hybrid retrieval (dense + BM25 reciprocal rank fusion)
HYBRID_SEARCH_ENABLED=true
HYBRID_FETCH_MULTIPLIER=4
HYBRID_RRF_K=60
BM25_INDEX_PATH=data/index/bm25_corpus.json

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production example:
# CORS_ORIGINS=https://conscrag.com,https://www.conscrag.com,https://your-app.vercel.app
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
CORS_ORIGIN_REGEX=

# Admin review (set a strong secret; used in X-Admin-Key header)
ADMIN_API_KEY=change-me-to-a-strong-secret

# Innovation gate thresholds
NOVELTY_DUPLICATE_THRESHOLD=0.88
NOVELTY_AUTO_REJECT_SCORE=35
NOVELTY_MIN_DISCIPLINES=2
INNOVATION_COLLECTION_NAME=innovation_vectors
